{
  "name": "omnipilot-ai-root",
  "version": "1.0.0",
  "description": "OmniPilot AI Multi-Agent System root runner",
  "scripts": {
    "install:all": "npm run install:backend && npm run install:frontend",
    "install:backend": "npm --prefix backend install",
    "install:frontend": "npm --prefix frontend install",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
